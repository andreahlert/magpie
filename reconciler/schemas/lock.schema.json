{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://magpie.apache.org/schemas/lock.v1.json",
  "title": "Adopter lock",
  "description": "Generated by the reconciler from intent.yaml + framework registry. Committed by the adopter. Captures the exact resolved set of skills, versions, integrations, and exclusions. Read by tooling that materialises the adopter workspace.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema-version",
    "generated-from",
    "generated-at",
    "framework-version",
    "skills"
  ],
  "properties": {
    "schema-version": {
      "type": "integer",
      "const": 1
    },
    "generated-from": {
      "type": "string",
      "description": "Relative path to the intent file this lock was generated from."
    },
    "generated-at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp the reconciler emitted this lock."
    },
    "framework-version": {
      "type": "string",
      "description": "Magpie framework version active when the lock was generated.",
      "pattern": "^\\d+\\.\\d+\\.\\d+(?:-[A-Za-z0-9.-]+)?$"
    },
    "skills": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["version", "source"],
        "properties": {
          "version": {
            "type": "string",
            "pattern": "^\\d+\\.\\d+\\.\\d+(?:-[A-Za-z0-9.-]+)?$"
          },
          "source": {
            "type": "string",
            "enum": [
              "intent.domains",
              "intent.overrides.force-include",
              "skill.requires"
            ],
            "description": "Why this skill landed in the lock. Useful for diffs and audits."
          },
          "integrations-resolved": {
            "type": "array",
            "uniqueItems": true,
            "items": { "type": "string" }
          },
          "params": {
            "type": "object",
            "description": "Effective params after defaults + intent.overrides.params merge."
          }
        }
      }
    },
    "exclusions": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["reason"],
        "properties": {
          "reason": {
            "type": "string",
            "enum": [
              "intent.overrides.exclude",
              "intent.capabilities.domains",
              "intent.capabilities.audiences",
              "intent.capabilities.risk-tier-max",
              "intent.capabilities.integrations"
            ]
          }
        }
      },
      "description": "Skill ids that exist in the framework but were left out, with the reason. Helps adopters spot when raising risk-tier-max would unlock something."
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "message"],
        "properties": {
          "code": { "type": "string" },
          "message": { "type": "string" },
          "skill": { "type": "string" }
        }
      }
    },
    "checksum": {
      "type": "string",
      "description": "sha256 of the canonical-serialised content above. Drift detector compares this to the on-disk lock.",
      "pattern": "^sha256:[0-9a-f]{64}$"
    }
  }
}
